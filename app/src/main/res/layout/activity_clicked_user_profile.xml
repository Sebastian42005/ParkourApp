<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:id="@+id/profileFragmentLayout">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:id="@+id/profileNameLayout">

            <ImageView
                android:id="@+id/backToMainMenuBtn"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="10dp"
                android:layout_marginTop="10dp"
                android:foreground="@drawable/ic_baseline_arrow_back_ios_24"
                android:foregroundTint="@color/black"/>

            <TextView
                android:id="@+id/profileUsername"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_toEndOf="@id/backToMainMenuBtn"
                android:gravity="center_vertical"
                android:text="Sebastian"
                android:textColor="@color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/goToUserChatActivityBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="5dp"
                android:layout_centerVertical="true"
                android:foreground="@drawable/ic_baseline_chat_24"
                android:foregroundTint="@color/black"
                android:layout_alignParentEnd="true"/>

        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/profileNameLayout"
            android:overScrollMode="never"
            android:scrollbars="none">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/white">

                <ImageView
                    android:id="@+id/profileBannerImageView"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:background="@color/white"
                    android:scaleType="fitXY"
                    android:src="@drawable/banner" />

                <TextView
                    android:id="@+id/space"
                    android:layout_width="100dp"
                    android:layout_height="50dp" />

                <TextView
                    android:id="@+id/space2"
                    android:layout_width="100dp"
                    android:layout_height="75dp" />


                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/profilePicImageView"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:layout_below="@id/space"
                    android:layout_marginStart="10dp"
                    android:src="@drawable/profile"
                    app:civ_border_color="#000000"
                    app:civ_border_width="3dp"/>

                <TextView
                    android:id="@+id/profileDescriptionTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/profilePicImageView"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:text="test\ntest"
                    android:textColor="@color/black"
                    android:textSize="18sp" />

                <Button
                    android:id="@+id/followBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/space2"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="30dp"
                    android:backgroundTint="@color/dark_aqua"
                    android:text="Follow"
                    android:textColor="@color/white" />

                <LinearLayout
                    android:id="@+id/profileImagesListLinearLayout"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_below="@id/profileDescriptionTextView"
                    android:layout_marginStart="2dp"
                    android:layout_marginTop="5dp"
                    android:layout_marginEnd="2dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layout1"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical" />


                    <LinearLayout
                        android:id="@+id/layout2"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical" />

                    <LinearLayout
                        android:id="@+id/layout3"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical" />

                </LinearLayout>

            </RelativeLayout>

        </ScrollView>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        android:id="@+id/profilePostsLayout">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:id="@+id/actionBar">

            <ImageView
                android:id="@+id/backBtn"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:foreground="@drawable/ic_baseline_arrow_back_24"
                android:foregroundTint="@color/black"
                android:layout_marginStart="5dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:gravity="center_vertical"
                android:text="Posts"
                android:textSize="20sp"
                android:layout_marginStart="5dp"
                android:textColor="@color/black"
                android:textStyle="bold"
                android:layout_toEndOf="@id/backBtn"/>

        </RelativeLayout>

        <ListView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never"
            android:background="@null"
            android:scrollbars="none"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:layout_below="@id/actionBar"
            android:id="@+id/postListView"/>

    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        android:id="@+id/friendsRequestsLayout">

        <RelativeLayout
            android:id="@+id/friendRequestsTopBar"
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="Friend Requests"
                android:textSize="18sp"
                android:gravity="center"
                android:textStyle="bold"
                android:textColor="@color/black"/>

            <ImageView
                android:id="@+id/friendsRequestsBackBtn"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:rotation="270"
                android:layout_marginStart="5dp"
                android:layout_marginTop="2dp"
                android:foreground="@drawable/ic_baseline_arrow_back_ios_24"
                android:foregroundTint="@color/dark_grey"/>

        </RelativeLayout>

        <ListView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/friendRequestsTopBar"
            android:id="@+id/friendsRequestsListView"/>

    </RelativeLayout>

</RelativeLayout>