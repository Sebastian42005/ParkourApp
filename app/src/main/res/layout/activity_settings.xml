<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    tools:context=".settings.SettingsActivity">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp">

            <ImageView
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:foreground="@drawable/ic_baseline_arrow_back_24"
                android:foregroundTint="@color/black"
                android:layout_centerVertical="true"/>

        </RelativeLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Settings"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:gravity="center"
            android:id="@+id/actionBar"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/black"
            android:layout_below="@id/actionBar"/>

        <ListView
            android:id="@+id/settingsListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/actionBar" />

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/joinTeamLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:visibility="gone"
        android:background="@color/transparent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="50dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/login_background_drawable"
            android:layout_centerInParent="true"
            android:layout_marginStart="50dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join Team"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:layout_marginBottom="15dp"
                android:layout_marginTop="10dp"/>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edit_text_background"
                    android:layout_alignBottom="@id/teamKeyEditText"
                    android:layout_alignEnd="@id/view"
                    android:layout_alignStart="@id/teamKeyEditText"
                    android:layout_alignTop="@id/teamKeyEditText"/>

                <EditText
                    android:id="@+id/teamKeyEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_toStartOf="@id/pasteBtn"
                    android:backgroundTint="#00000000"
                    android:hint="Team Key" />

                <ImageView
                    android:id="@+id/pasteBtn"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/paste"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="25dp"/>

                <View
                    android:id="@+id/view"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/paste"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="20dp"/>

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edit_text_background"
                    android:layout_alignBottom="@id/teamPasswordEditText"
                    android:layout_alignEnd="@id/teamPasswordEditText"
                    android:layout_alignStart="@id/teamPasswordEditText"
                    android:layout_alignTop="@id/teamPasswordEditText"/>

                <EditText
                    android:id="@+id/teamPasswordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="15dp"
                    android:backgroundTint="#00000000"
                    android:hint="Password" />

            </RelativeLayout>

            <Button
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Join"
                android:backgroundTint="#00ccc5"
                android:textColor="@color/black"
                android:layout_marginBottom="10dp"
                android:id="@+id/joinTeamBtn"/>

        </LinearLayout>

    </RelativeLayout>

</RelativeLayout>