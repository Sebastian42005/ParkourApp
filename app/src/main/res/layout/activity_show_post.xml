<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_baseline_arrow_back_24"
        android:id="@+id/backBtn"/>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/backBtn">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profilePicImageView"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_below="@id/space"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:src="@drawable/profile"
            app:civ_border_color="#FFFFFF"
            app:civ_border_width="3dp"
            tools:ignore="NotSibling" />


        <TextView
            android:id="@+id/postUsername"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginStart="10dp"
            android:layout_marginTop="10dp"
            android:layout_toEndOf="@id/profilePicImageView"
            android:gravity="center_vertical"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/postImage"
            android:layout_width="400dp"
            android:layout_height="400dp"
            android:layout_below="@id/postUsername" />

        <ImageView
            android:id="@+id/likePostImageView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_below="@id/postImage"
            android:layout_marginStart="5dp"
            android:foreground="@drawable/ic_baseline_star_outline_24"
            tools:ignore="UnusedAttribute" />

        <TextView
            android:id="@+id/postLikeAmountTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/likePostImageView"
            android:layout_marginStart="10dp"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/postDescriptionTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:layout_below="@id/postLikeAmountTextView"
            android:layout_marginStart="10dp"/>

    </RelativeLayout>

</RelativeLayout>