<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="visible"
        android:id="@+id/loginRelativeLayout">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/login_background" />

        <TextView
            android:id="@+id/loginTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/image"
            android:layout_centerHorizontal="true"
            android:text="@string/login"
            android:textColor="@color/dark_blue"
            android:textSize="50sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/loginLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/loginTextView"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:background="@drawable/login_background_drawable"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edit_text_background"
                    android:layout_alignBottom="@id/loginEmailEditText"
                    android:layout_alignEnd="@id/loginEmailEditText"
                    android:layout_alignStart="@id/loginEmailEditText"
                    android:layout_alignTop="@id/loginEmailEditText"/>

                <EditText
                    android:id="@+id/loginEmailEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="50dp"
                    android:layout_marginRight="20dp"
                    android:backgroundTint="#00000000"
                    android:hint="@string/email"
                    android:inputType="textEmailAddress" />

            </RelativeLayout>

            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/edit_text_background"
                    android:layout_alignBottom="@id/loginPasswordEditText"
                    android:layout_alignEnd="@id/loginPasswordEditText"
                    android:layout_alignStart="@id/loginPasswordEditText"
                    android:layout_alignTop="@id/loginPasswordEditText"/>

                <EditText
                    android:id="@+id/loginPasswordEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="20dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginRight="20dp"
                    android:layout_marginBottom="40dp"
                    android:backgroundTint="#00000000"
                    android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890횩철횜채횆체횥_-!.,;"
                    android:hint="@string/password"
                    android:inputType="textPassword" />

            </RelativeLayout>

        </LinearLayout>

        <Button
            android:id="@+id/loginBtn"
            android:layout_width="210dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/loginLayout"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/dark_blue"
            android:text="@string/login" />

        <TextView
            android:id="@+id/registerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/loginBtn"
            android:layout_centerHorizontal="true"
            android:textSize="17sp"
            android:layout_marginTop="5dp"
            android:textColor="@color/black"
            android:text="@string/register" />

        <TextView
            android:id="@+id/passwordResetTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/registerTextView"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="3dp"
            android:textSize="17sp"
            android:textColor="@color/black"
            android:text="@string/reset_password" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="?android:attr/progressBarStyleLarge"
            android:visibility="gone"
            android:layout_centerInParent="true"/>

        <ImageView
            android:id="@+id/image"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:foreground="@drawable/parkour"
            android:foregroundTint="@color/dark_blue" />

    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/login_background"
        android:id="@+id/registerRelativeLayout"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:visibility="gone">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <TextView
                android:id="@+id/registerTitleTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/registerImage"
                android:text="Register"
                android:textColor="@color/dark_blue"
                android:textSize="50sp"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/registerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/registerTitleTextView"
                android:layout_marginTop="20dp"
                android:layout_marginLeft="30dp"
                android:layout_marginRight="30dp"
                android:background="@drawable/login_background_drawable"
                android:orientation="vertical">

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edit_text_background"
                        android:layout_alignBottom="@id/registerUsernameEditText"
                        android:layout_alignEnd="@id/registerUsernameEditText"
                        android:layout_alignStart="@id/registerUsernameEditText"
                        android:layout_alignTop="@id/registerUsernameEditText"/>

                    <EditText
                        android:id="@+id/registerUsernameEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:layout_marginTop="50dp"
                        android:layout_marginRight="20dp"
                        android:backgroundTint="#00000000"
                        android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890횩철횜채횆체횥_"
                        android:hint="@string/username"
                        android:inputType="text" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edit_text_background"
                        android:layout_alignBottom="@id/registerEmailEditText"
                        android:layout_alignEnd="@id/registerEmailEditText"
                        android:layout_alignStart="@id/registerEmailEditText"
                        android:layout_alignTop="@id/registerEmailEditText"/>

                    <EditText
                        android:id="@+id/registerEmailEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginRight="20dp"
                        android:backgroundTint="#00000000"
                        android:hint="Email"
                        android:inputType="textEmailAddress" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edit_text_background"
                        android:layout_alignBottom="@id/registerPasswordEditText"
                        android:layout_alignEnd="@id/registerPasswordEditText"
                        android:layout_alignStart="@id/registerPasswordEditText"
                        android:layout_alignTop="@id/registerPasswordEditText"/>

                    <EditText
                        android:id="@+id/registerPasswordEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginRight="20dp"
                        android:inputType="textPassword"
                        android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890횩철횜채횆체횥_!-"
                        android:backgroundTint="#00000000"
                        android:hint="@string/password" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edit_text_background"
                        android:layout_alignBottom="@id/registerCountryEditText"
                        android:layout_alignEnd="@id/registerCountryEditText"
                        android:layout_alignStart="@id/registerCountryEditText"
                        android:layout_alignTop="@id/registerCountryEditText"/>

                    <EditText
                        android:id="@+id/registerCountryEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:inputType="text"
                        android:layout_marginTop="20dp"
                        android:layout_marginRight="20dp"
                        android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890횩철횜채횆체횥_-"
                        android:backgroundTint="#00000000"
                        android:hint="@string/country" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edit_text_background"
                        android:layout_alignBottom="@id/registerCityEditText"
                        android:digits="abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ1234567890횩철횜채횆체횥_-"
                        android:layout_alignEnd="@id/registerCityEditText"
                        android:layout_alignStart="@id/registerCityEditText"
                        android:layout_alignTop="@id/registerCityEditText"/>

                    <EditText
                        android:id="@+id/registerCityEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:layout_marginTop="20dp"
                        android:inputType="text"
                        android:layout_marginRight="20dp"
                        android:backgroundTint="#00000000"
                        android:hint="@string/city" />

                </RelativeLayout>

                <RelativeLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/edit_text_background"
                        android:layout_alignBottom="@id/registerAgeEditText"
                        android:layout_alignEnd="@id/registerAgeEditText"
                        android:layout_alignStart="@id/registerAgeEditText"
                        android:layout_alignTop="@id/registerAgeEditText"/>

                    <EditText
                        android:id="@+id/registerAgeEditText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginRight="20dp"
                        android:layout_marginBottom="40dp"
                        android:backgroundTint="#00000000"
                        android:hint="@string/age"
                        android:inputType="number" />

                </RelativeLayout>

            </LinearLayout>

            <Button
                android:id="@+id/registerBtn"
                android:layout_width="210dp"
                android:layout_height="wrap_content"
                android:layout_below="@id/registerLayout"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/dark_blue"
                android:text="@string/register" />

            <ProgressBar
                android:id="@+id/registerProgressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="?android:attr/progressBarStyleLarge"
                android:visibility="gone"
                android:layout_centerInParent="true"/>

            <ImageView
                android:id="@+id/registerImage"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="40dp"
                android:foreground="@drawable/parkour"
                android:foregroundTint="@color/dark_blue" />

            <ImageView
                android:id="@+id/registerBackBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:src="@drawable/ic_baseline_arrow_back_24" />

        </RelativeLayout>

    </ScrollView>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:visibility="gone"
        android:id="@+id/resetPasswordRelativeLayout">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/login_background" />

        <TextView
            android:id="@+id/resetPasswordTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/passwordImage"
            android:layout_centerHorizontal="true"
            android:text="@string/reset_password"
            android:gravity="center"
            android:textColor="@color/dark_blue"
            android:textSize="50sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:id="@+id/resetPasswordLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/resetPasswordTextView"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp"
            android:background="@drawable/login_background_drawable">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/edit_text_background"
                android:layout_alignBottom="@id/resetEmailEditText"
                android:layout_alignEnd="@id/resetEmailEditText"
                android:layout_alignStart="@id/resetEmailEditText"
                android:layout_alignTop="@id/resetEmailEditText"/>

            <EditText
                android:id="@+id/resetEmailEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="30dp"
                android:layout_marginRight="20dp"
                android:backgroundTint="#00000000"
                android:hint="@string/email"
                android:inputType="textEmailAddress" />

        </RelativeLayout>

        <Button
            android:id="@+id/resetPasswordBtn"
            android:layout_width="210dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/resetPasswordLayout"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="20dp"
            android:backgroundTint="@color/dark_blue"
            android:text="@string/reset" />

        <ImageView
            android:id="@+id/passwordImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:foreground="@drawable/parkour"
            android:foregroundTint="@color/dark_blue" />

        <ImageView
            android:id="@+id/resetPasswordBackBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="5dp"
            android:layout_marginTop="5dp"
            android:src="@drawable/ic_baseline_arrow_back_24" />

    </RelativeLayout>

</RelativeLayout>